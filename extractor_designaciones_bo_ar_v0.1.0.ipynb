   "source": [
    "import requests\n",
    "from bs4 import BeautifulSoup\n",
    "import time\n",
    "import pandas as pd\n",
    "\n",
    "# 1. Conexión con la web del B.O.\n",
    "url_portada = \"https://www.boletinoficial.gob.ar/seccion/primera\"\n",
    "cabeceras = {\n",
    "    \"User-Agent\": \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36\"\n",
    "}\n",
    "\n",
    "print(f\"Conectando al Boletín Oficial...\")\n",
    "respuesta = requests.get(url_portada, headers=cabeceras)\n",
    "\n",
    "if respuesta.status_code == 200:\n",
    "    sopa = BeautifulSoup(respuesta.text, 'html.parser')\n",
    "    \n",
    "# 2. Detección de los links del boletín del día de la fecha\n",
    "    enlaces = sopa.find_all('a')\n",
    "    links_normativas = []\n",
    "    \n",
    "    for enlace in enlaces:\n",
    "        url_extraida = enlace.get('href')\n",
    "        \n",
    "        if url_extraida is not None and \"/detalleAviso/\" in url_extraida:\n",
    "            link_completo = \"https://www.boletinoficial.gob.ar\" + url_extraida\n",
    "            \n",
    "            if link_completo not in links_normativas: \n",
    "                links_normativas.append(link_completo)\n",
    "\n",
    "    print(f\"¡Éxito! Se encontraron {len(links_normativas)} normativas publicadas hoy.\")\n",
    "\n",
    "# 3. Armado de estructura de la lista\n",
    "    print(\"-\" * 50)\n",
    "    print(\"Detectando las normativas sobre designaciones. Aguarde por favor\")\n",
    "    \n",
    "    designaciones_confirmadas = []\n",
    "    \n",
    "    for link in links_normativas: \n",
    "        \n",
    "        respuesta_interna = requests.get(link, headers=cabeceras)\n",
    "        \n",
    "        if respuesta_interna.status_code == 200:\n",
    "            sopa_interna = BeautifulSoup(respuesta_interna.text, 'html.parser')\n",
    "            \n",
    "            # Valores por defecto para evitar arrastre de datos en caso de fallas HTML\n",
    "            organismo_normativa = \"No especificado\"\n",
    "            nombre_normativa = \"No especificado\"\n",
    "            fecha_normativa = \"No especificada\"\n",
    "            \n",
    "            # Lógica de extracción de títulos. H1 refiere a organismos y H2 a nombre de la normativa\n",
    "            bloque_titulos = sopa_interna.find('div', id='tituloDetalleAviso')\n",
    "            if bloque_titulos is not None:\n",
    "                h1_hijo = bloque_titulos.find('h1')\n",
    "                h2_hijo = bloque_titulos.find('h2')\n",
    "\n",
    "                if h1_hijo is not None:\n",
    "                    organismo_normativa = h1_hijo.text.strip()\n",
    "                if h2_hijo is not None:\n",
    "                    nombre_normativa = h2_hijo.text.strip()\n",
    "\n",
    "            etiqueta_fecha = sopa_interna.find('p', class_='text-muted')\n",
    "            if etiqueta_fecha is not None:\n",
    "                texto_fecha = etiqueta_fecha.text.strip()\n",
    "                fecha_normativa = texto_fecha.replace(\"Fecha de publicación\", \"\").strip()\n",
    "            \n",
    "            texto_normativa = sopa_interna.text.lower()\n",
    "            \n",
    "# 4. Filtro de designación\n",
    "            if \"designa\" in texto_normativa:\n",
    "                print(f\">>> MATCH: {organismo_normativa} - {nombre_normativa}\")\n",
    "                \n",
    "                paquete = {\n",
    "                    \"Organismo\": organismo_normativa,\n",
    "                    \"Normativa\": nombre_normativa,\n",
    "                    \"Fecha\": fecha_normativa,\n",
    "                    \"Link\": link\n",
    "                }\n",
    "                designaciones_confirmadas.append(paquete)\n",
    "                \n",
    "        time.sleep(1) \n",
    "        \n",
    "    print(\"-\" * 50)\n",
    "    print(f\"Completado: Se encontraron {len(designaciones_confirmadas)} designaciones para el boletín del día de la fecha.\")\n",
    "\n",
    "    print(\"-\" * 50)\n",
    "    print(\"Exportando la información. Aguarde.\")\n",
    "\n",
    "# 5. Exportación en .xlsx     \n",
    "    if len(designaciones_confirmadas) > 0:\n",
    "    \n",
    "        df_designaciones = pd.DataFrame(designaciones_confirmadas)\n",
    "    \n",
    "        print(\"Vista previa:\")\n",
    "        print(df_designaciones.head())\n",
    "    \n",
    "        nombre_archivo = \"designaciones_bo_argentina.xlsx\"\n",
    "        df_designaciones.to_excel(nombre_archivo, index=False)\n",
    "    \n",
    "        print(\"-\" * 50)\n",
    "        print(f\"ÉXITO: El archivo '{nombre_archivo}' se generó correctamente en tu carpeta local.\")\n",
    "\n",
    "    else:\n",
    "        print(\"No se encontraron designaciones hoy. No se generó ningún archivo Excel.\")\n",
    "        \n",
    "else:\n",
    "    print(f\"Error de conexión. Código: {respuesta.status_code}\")"
   ]
  },
